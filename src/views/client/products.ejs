<%- include('../partials/header') %>
<section class="page-title">
  <h1>Sản phẩm</h1>
  <p>Lọc linh kiện theo danh mục và hiệu năng.</p>
</section>

<form class="filter-bar" action="/products" method="get">
  <input type="search" name="keyword" placeholder="Tên hoặc hãng" value="<%= filters.keyword || '' %>">
  <select name="category">
    <option value="">Tất cả danh mục</option>
    <% categories.forEach((category) => { %>
      <option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= category %></option>
    <% }) %>
  </select>
  <select name="minPerformance">
    <option value="">Mọi hiệu năng</option>
    <option value="80" <%= filters.minPerformance === '80' ? 'selected' : '' %>>Từ 80 điểm</option>
    <option value="90" <%= filters.minPerformance === '90' ? 'selected' : '' %>>Từ 90 điểm</option>
  </select>
  <button class="btn primary" type="submit">Lọc</button>
</form>

<div class="product-grid">
  <% products.forEach((product) => { %>
    <article class="product-card">
      <img src="<%= product.image %>" alt="<%= product.name %>">
      <p class="category"><%= product.category %> - <%= product.brand %></p>
      <h3><%= product.name %></h3>
      <p>Hiệu năng: <strong><%= product.performance %>/100</strong></p>
      <p class="price"><%= product.price.toLocaleString('vi-VN') %>đ</p>
      <div class="card-actions">
        <a class="btn small" href="/products/<%= product.id %>">Chi tiết</a>
        <% if (user) { %>
          <form action="/cart/add/<%= product.id %>" method="post"><button class="btn small primary" type="submit">Thêm</button></form>
        <% } else { %>
          <a class="btn small primary" href="/login">Đăng nhập để mua</a>
        <% } %>
      </div>
    </article>
  <% }) %>
</div>
<% if (!products.length) { %>
  <p class="empty-state">Không tìm thấy linh kiện phù hợp.</p>
<% } %>
<%- include('../partials/footer') %>
