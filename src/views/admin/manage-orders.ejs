<%- include('../partials/header') %>
<div class="admin-layout">
  <%- include('../partials/admin_sidebar') %>
  <section class="admin-content">
    <h1>Quản lý đơn hàng</h1>
    <table class="admin-table">
      <tr><th>Mã</th><th>Khách hàng</th><th>Ngày</th><th>Tổng</th><th>Trạng thái</th><th>Cập nhật</th></tr>
      <% orders.forEach((order) => { %>
        <tr>
          <td>#<%= order.id %></td>
          <td><%= order.customer %></td>
          <td><%= order.createdAt %></td>
          <td><%= order.total.toLocaleString('vi-VN') %>đ</td>
          <td><%= order.status %></td>
          <td>
            <form action="/admin/orders/<%= order.id %>/status" method="post" class="status-form">
              <select name="status">
                <% ['Chờ duyệt', 'Đang giao', 'Hoàn tất', 'Đã hủy'].forEach((status) => { %>
                  <option value="<%= status %>" <%= order.status === status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
              </select>
              <button type="submit">Lưu</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </table>
  </section>
</div>
<%- include('../partials/footer') %>
